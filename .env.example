# Copy to .env and fill in secrets. Compose reads ANTHROPIC_API_KEY from the shell/.env.

# --- Data stores ---
DATABASE_URL=postgresql+asyncpg://smartcourse:smartcourse@localhost:5432/smartcourse
MONGO_URL=mongodb://localhost:27017
MONGO_DB=smartcourse
REDIS_URL=redis://localhost:6379/0

# --- Vector DB ---
QDRANT_URL=http://localhost:6333

# --- Messaging / streaming ---
RABBITMQ_URL=amqp://guest:guest@localhost:5672//
KAFKA_BOOTSTRAP_SERVERS=localhost:29092
SCHEMA_REGISTRY_URL=http://localhost:8081

# --- Workflows ---
TEMPORAL_HOST=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=smartcourse

# --- AI / LLM (default provider = anthropic; also: openai, groq) ---
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5
# OPENAI_API_KEY=
# GROQ_API_KEY=

# --- Email notifications (console logs the email; smtp sends it) ---
EMAIL_BACKEND=console
EMAIL_FROM=SmartCourse <no-reply@smartcourse.dev>
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_USE_TLS=true

# --- Observability ---
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=smartcourse-api

# --- App ---
ENVIRONMENT=local
LOG_LEVEL=INFO
